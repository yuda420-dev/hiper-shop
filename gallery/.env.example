# Supabase Configuration
# Get these from your Supabase project settings: Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic API Key (optional — enables AI-powered artwork description generation)
# Get from https://console.anthropic.com/settings/api-keys
# NOTE: This key is exposed in the browser bundle. Use a scoped key with rate limits.
VITE_ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
