# Supabase Configuration (shared with gallery — same project)
# Get from Supabase: Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe Configuration
# Publishable key is safe to expose client-side
VITE_STRIPE_PUBLIC_KEY=pk_test_your-publishable-key-here
# Secret key is server-side only (used in Vercel serverless functions)
STRIPE_SECRET_KEY=sk_test_your-secret-key-here
# Webhook secret — get from Stripe Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Prodigi Print-on-Demand API
# Get from https://www.prodigi.com/account/api-keys/
PRODIGI_API_KEY=your-prodigi-api-key-here
